# Wodify API
WODIFY_API_KEY=your_wodify_api_key_here
WODIFY_API_URL=https://api.wodify.com/v1

# Bexio API
BEXIO_API_TOKEN=your_bexio_personal_access_token_here
BEXIO_API_URL=https://api.bexio.com

# Bexio Sync Configuration (required for InvoiceSyncService)
# Note: bank_account_id is auto-fetched during InvoiceSyncService.initialize()
# Note: Contacts get user_id from a fictional user created automatically for each customer

# Owner ID for created records (contacts & invoices)
BEXIO_OWNER_ID=1
# Account ID for revenue (e.g., 3200 = sales revenue)
BEXIO_INVOICE_ACCOUNT_NO=3200
# Your bank IBAN (used to look up bank account)
BEXIO_INVOICE_IBAN=CH00 0000 0000 0000 0000 0
# Default country ID for new contacts (1 = Switzerland)
BEXIO_DEFAULT_COUNTRY_ID=1
# Sales tax ID for invoice line items (see README for how to get available tax IDs)
BEXIO_TAX_ID=28



# Optional: GCP Project (for logging/monitoring)
GCP_PROJECT_ID=your_gcp_project_id

# Optional: Polling interval in minutes (how often to check for changes)
POLL_INTERVAL_MINUTES=15

# Optional: Buffer in hours added to polling window to ensure no invoices are missed
POLL_BUFFER_HOURS=24
